# Copy to .env and fill in at the Supabase stage (handoff step 4).
# Only the ANON (public) key goes here. NEVER put the service-role key in a
# VITE_-prefixed var — it would be shipped to the browser. Use it only in a
# Cloudflare Pages Function / Supabase Edge Function.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
